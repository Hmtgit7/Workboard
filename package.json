{
  "name": "workboard",
  "version": "1.0.0",
  "description": "Professional monorepo workspace",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --recursive --parallel run dev",
    "build": "pnpm --recursive run build",
    "start": "pnpm --recursive run start",
    "lint": "pnpm --recursive run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss}\"",
    "type-check": "pnpm --recursive run type-check",
    "test": "pnpm --recursive run test",
    "clean": "pnpm --recursive run clean && rimraf node_modules",
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "commit": "cz commit"
  },
  "keywords": [
    "monorepo",
    "nextjs",
    "typescript",
    "prisma"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.4",
    "prettier": "^3.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^6"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "pnpm": {
    "overrides": {
      "typescript": "^6"
    }
  }
}
